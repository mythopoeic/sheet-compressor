# Local reference implementations — contain a previously-leaked API key; NEVER commit
sources/

# Dependencies
node_modules/
**/node_modules/

# Claude Code / sandcastle tooling (not part of the product)
.claude/
.agents/
.sandcastle/
# Local patch-package fixes for the gitignored sandcastle tooling (root package.json
# carries the matching postinstall hook, also untracked) — kept local, not shipped.
patches/

# Root-level tooling manifests (product packages carry their own under packages/)
/package.json
/package-lock.json
/skills-lock.json

# Environment / secrets
.env
*.env
!**/.env.example
.env.local

# Build output
dist/
build/
bin/
obj/
*.tsbuildinfo

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Transient copy made by `npm pack` prepack (see packages/typescript/package.json)
/packages/typescript/prompts/

# Local scratch artifacts from in-host testing (generated workbooks, conformance
# run output, and non-committed example reconstructions). The committed examples
# use the `-sparse` suffix and are NOT matched here.
/packages/vba/*.xlsm
/fixtures/vba-conformance-report.txt
/examples/aetherium-576x23.xlsx
/examples/aetherium-576x23.grid.json
/examples/paper-figure2-example.xlsx
/examples/paper-figure2-example.grid.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
