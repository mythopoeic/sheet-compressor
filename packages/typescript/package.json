{
  "name": "sheet-compressor",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript reference implementation of the SheetCompressor encoding from the SpreadsheetLLM paper.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "prompts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-goldens": "tsx scripts/generate-goldens.ts",
    "prepack": "node -e \"require('node:fs').cpSync('../../prompts','./prompts',{recursive:true})\"",
    "postpack": "node -e \"require('node:fs').rmSync('./prompts',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "gpt-tokenizer": "^3.4.0",
    "xlsx": "^0.18.5"
  }
}
