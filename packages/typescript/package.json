{
  "name": "sheet-compressor",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript reference implementation of the SheetCompressor encoding from the SpreadsheetLLM paper.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
