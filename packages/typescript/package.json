{
  "name": "sheet-compressor",
  "version": "0.1.1",
  "description": "Independent TypeScript implementation of the SpreadsheetLLM SheetCompressor encoding for token-efficient LLM workflows.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mythopoeic/sheet-compressor.git",
    "directory": "packages/typescript"
  },
  "homepage": "https://github.com/mythopoeic/sheet-compressor/tree/main/packages/typescript",
  "bugs": {
    "url": "https://github.com/mythopoeic/sheet-compressor/issues"
  },
  "keywords": [
    "spreadsheet",
    "llm",
    "tokenization",
    "compression",
    "excel",
    "prompt-engineering",
    "spreadsheetllm"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-goldens": "tsx scripts/generate-goldens.ts",
    "prepack": "npm run build && node -e \"require('node:fs').cpSync('../../prompts','./prompts',{recursive:true})\"",
    "postpack": "node -e \"require('node:fs').rmSync('./prompts',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "gpt-tokenizer": "^3.4.0",
    "xlsx": "^0.18.5"
  }
}
